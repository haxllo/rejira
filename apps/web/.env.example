# Vars the Next.js client bundle reads at build time.
# The full list of server-side secrets lives at the repo root `.env.example`.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-name.convex.site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL for the Better Auth API proxy (same as the app in most deploys).
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
