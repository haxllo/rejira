# ─── Convex ────────────────────────────────────────────────
# Created automatically by `npx convex dev` — DO NOT commit
# the populated `.env.local` that the CLI generates.
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment-name.convex.cloud
CONVEX_SITE_URL=https://your-deployment-name.convex.site

# Public vars exposed to the browser (Next.js inlines NEXT_PUBLIC_* at build time).
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-name.convex.site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Better Auth (3A+) ───────────────────────────────────
# Secret used to sign session tokens and CSRF tokens.
# Min 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Must be set as a Convex env var (not just .env.local) because the Better
# Auth instance runs on the Convex backend. Set it via:
#   npx convex env set BETTER_AUTH_SECRET <value>
BETTER_AUTH_SECRET=

# Public base URL of the app. Used for:
# - Generating email links (sign-in, verify, reset)
# - OAuth provider redirect URIs
# In dev, set this to your ngrok URL when testing OAuth:
#   BETTER_AUTH_URL=https://xxx.ngrok.io
# In prod, set this to the canonical app URL.
BETTER_AUTH_URL=http://localhost:3000

# ─── Email transport (3B+) ────────────────────────────────
# Resend API key for transactional email. Optional in dev —
# the email transport falls back to ConsoleTransport which
# logs the rendered email to the terminal.
# Get a key at: https://resend.com/api-keys
RESEND_API_KEY=

# Email "From" address. Must be on a domain you've verified
# in Resend. In dev, use the Resend sandbox:
#   onboarding@resend.dev (delivers only to the address that
#   owns the Resend account)
RESEND_FROM=Rejira <noreply@rejira.app>

# ─── OAuth providers (3C+) ────────────────────────────────
# Google OAuth credentials from https://console.cloud.google.com
# Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials from https://github.com/settings/developers
# Authorization callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
